# ==========================================================
# Autonomous DBA Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# IMPORTANT: No inline comments after values — python-dotenv
#            treats everything after # as part of the value.
# ==========================================================


# ----------------------------------------------------------
# DATABASE TARGETS
# Comma-separated connection URLs for databases to monitor.
# Supported schemes: postgresql:// or mysql://
# ----------------------------------------------------------
MONITORED_DBS=postgresql://dba_agent:password@localhost:5432/mydb,mysql://dba_agent:password@localhost:3306/mydb


# ----------------------------------------------------------
# AGENT METRIC STORE (TimescaleDB)
# Separate database where the agent writes its own metrics.
# Runs on port 5433 by default to avoid clash with monitored DB.
# ----------------------------------------------------------
TIMESCALE_URL=postgresql://postgres:password@localhost:5433/dba_metrics


# ----------------------------------------------------------
# REDIS
# Used as Celery broker and LLM response cache.
# ----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0


# ----------------------------------------------------------
# LLM CONFIGURATION
# LLM_PROVIDER: "ollama" (local, default) or "groq" (cloud)
# Ollama runs locally — no API cost. Groq is the cloud fallback.
# ----------------------------------------------------------
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder:33b
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192


# ----------------------------------------------------------
# NOTIFICATIONS
# Leave SLACK_WEBHOOK_URL blank to disable Slack alerts.
# SLACK_CHANNEL must start with # — wrap in quotes if needed.
# ----------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=dba-alerts
NOTIFICATION_EMAIL=dba-team@company.com


# ----------------------------------------------------------
# AUTHENTICATION
# Change JWT_SECRET before deploying to any non-local env.
# ----------------------------------------------------------
JWT_SECRET=change-me-in-production
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your_client_id


# ----------------------------------------------------------
# MONITORING INTERVALS (seconds)
# CRITICAL_POLL_INTERVAL:   connections, latency, locks
# SECONDARY_POLL_INTERVAL:  bloat, index usage, vacuum stats
# FORECAST_UPDATE_INTERVAL: capacity forecast refresh
# ----------------------------------------------------------
CRITICAL_POLL_INTERVAL=10
SECONDARY_POLL_INTERVAL=60
FORECAST_UPDATE_INTERVAL=3600


# ----------------------------------------------------------
# THRESHOLDS
# SLOW_QUERY_THRESHOLD_MS:      flag queries slower than this
# P99_REGRESSION_THRESHOLD:     0.10 = 10% regression triggers rollback
# MAX_MONITORING_OVERHEAD_PCT:  max extra load on monitored DB
# CAPACITY_WARNING_DAYS:        warn N days before projected breach
# ----------------------------------------------------------
SLOW_QUERY_THRESHOLD_MS=1000
P99_REGRESSION_THRESHOLD=0.10
MAX_MONITORING_OVERHEAD_PCT=2.0
CAPACITY_WARNING_DAYS=28


# ----------------------------------------------------------
# SHADOW DATABASE (for workload replay)
# Docker images used to spin up ephemeral shadow databases.
# ----------------------------------------------------------
SHADOW_DB_IMAGE=postgres:16-alpine
SHADOW_MYSQL_IMAGE=mysql:8.0
MAX_CONCURRENT_REPLAYS=10


# ----------------------------------------------------------
# COLD STORAGE (MinIO / S3)
# For archiving metrics older than the hot retention window.
# ----------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
COLD_STORAGE_BUCKET=dba-metrics-cold


# ----------------------------------------------------------
# APPLICATION
# LOG_LEVEL:   DEBUG | INFO | WARNING | ERROR
# ENVIRONMENT: development | staging | production
# ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development
